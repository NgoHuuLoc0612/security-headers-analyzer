# ─── Security Headers Analyzer — API Environment ──────────────

# Server
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=change-this-in-production-to-a-random-secret

# Cluster (horizontal scaling)
ENABLE_CLUSTER=false
MAX_CLUSTER_WORKERS=4

# PostgreSQL (EDB native)
# Format: postgresql://user:password@host:port/database?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/security_headers_analyzer?schema=public

# Redis (Memurai on Windows / Redis on Linux)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_METRICS_DB=3
REDIS_KEY_PREFIX=sha:

# External APIs
SSL_LABS_EMAIL=
VIRUSTOTAL_API_KEY=

# Analysis limits
MAX_CONCURRENT_ANALYSES=10
ANALYSIS_TIMEOUT_MS=60000
MAX_REDIRECTS=10

# Cache TTLs (seconds)
ANALYSIS_CACHE_TTL=3600
RESULTS_CACHE_TTL=300

# Queue backpressure
MAX_QUEUE_SIZE=1000
MAX_WAITING_IO=500
MAX_WAITING_CPU=200
MAX_WAITING_API=300

# Worker concurrency
IO_WORKER_CONCURRENCY=20
CPU_WORKER_CONCURRENCY=4
API_WORKER_CONCURRENCY=8

# Retry
MAX_JOB_ATTEMPTS=3
RETRY_BASE_DELAY_MS=2000

# Rate limiting (requests per window)
THROTTLE_SHORT_LIMIT=10
THROTTLE_MEDIUM_LIMIT=50
THROTTLE_LONG_LIMIT=200
